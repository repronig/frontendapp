# Local dev (recommended): same-origin via Vite proxy — run API with `php artisan serve` in api.repronig
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://127.0.0.1:8010

# Homestead/Valet only (after nginx serves api.repronig/public → index.php):
# VITE_API_PROXY_TARGET=https://api.repronig.local

# Direct API URL without Vite proxy (requires API CORS for http://localhost:5173):
# VITE_API_BASE_URL=https://api.repronig.local/api/v1
# VITE_API_PROXY_TARGET=
VITE_APP_NAME=REPRONIG Platform
VITE_RECAPTCHA_SITE_KEY=6LeKgOQsAAAAAGBtRSwNW7kR_z1InOhSyuzwknH6

# Google reCAPTCHA v2 checkbox (member + institution registration). Prefer API RECAPTCHA_SITE_KEY (exposed via GET /platform-settings); this Vite var is an optional fallback for local builds.
# VITE_RECAPTCHA_SITE_KEY=

# Playwright (npm run test:e2e): optional; defaults to http://127.0.0.1:5173. Set PLAYWRIGHT_SKIP_WEB_SERVER=1 if the app is already running.
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173
# PLAYWRIGHT_SKIP_WEB_SERVER=
# E2E_SUPER_EMAIL=
# E2E_SUPER_PASSWORD=
# If the super account uses 2FA and your API returns an email/code flow, set the 6-digit code for CI (short-lived) or use a test user without 2FA.
# E2E_2FA_CODE=
